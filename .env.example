DATABASE_URL=postgresql://user:password@localhost:5432/sentence_notebook
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
IDEMPOTENCY_WINDOW_DAYS=7

# AI 配置加密密钥（运行 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成）
AI_CONFIG_ENCRYPT_KEY=

# 平台默认文本 AI 配置（用户无自有 Key 时使用）
DEFAULT_TEXT_API_KEY=
DEFAULT_TEXT_ENDPOINT=https://api.openai.com/v1/chat/completions
DEFAULT_TEXT_MODEL=gpt-4o

# 平台默认视觉 AI 配置
DEFAULT_VISION_API_KEY=
DEFAULT_VISION_ENDPOINT=https://api.openai.com/v1/chat/completions
DEFAULT_VISION_MODEL=gpt-4o